{
  "name": "tenet-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "client"
  ],
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "dev:client": "cd client && npm run dev",
    "dev:all": "concurrently -n api,ui -c blue,magenta \"npm run dev\" \"npm run dev:client\"",
    "build:client": "cd client && npm run build",
    "build:server": "tsc -p tsconfig.json",
    "build:badge-worker": "tsc -p badge-worker/tsconfig.json",
    "build": "npm run build:client && npm run build:server",
    "deploy:badge-worker": "cd badge-worker && npx wrangler deploy",
    "start": "node dist/server/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx server/db/migrate.ts",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.6",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0"
  }
}
